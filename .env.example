# =====================================================
# OKAN SÜRÜCÜ KURSLARI — Environment Variables
# Netlify Dashboard → Site Settings → Environment Variables
# =====================================================

# Supabase Project URL (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anon/Public Key (safe to expose in frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (NEVER expose in frontend — only Netlify Functions)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Site URL for CORS
SITE_URL=https://your-site-name.netlify.app
